    # ==========================================
# ETAPE 4 : Analyse de la maladie (Cible)
# ==========================================

# On suppose que la colonne cible s'appelle 'target'
nom_cible = 'target'

counts = df[nom_cible].value_counts()
sains = counts.get(0, 0)
malades = counts.get(1, 0)

print(f"Nombre de patients sains (0) : {sains}")
